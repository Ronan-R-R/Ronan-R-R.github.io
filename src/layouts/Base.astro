---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'Ronan Roberts | Software Engineer',
  description = 'Software Engineer based in Germiston, Gauteng. Specialising in full-stack web development and cross-platform mobile apps with Flutter and Dart.',
} = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#08080D" />

  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://ronan-r-r.github.io" />

  <!-- Favicon -->
  <link
    rel="icon"
    type="image/svg+xml"
    href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%237C5CFF' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='16 18 22 12 16 6'%3E%3C/polyline%3E%3Cpolyline points='8 6 2 12 8 18'%3E%3C/polyline%3E%3C/svg%3E"
  />

  <slot name="head" />
</head>
<body>
  <slot />

  <script>
    import '../scripts/animations.ts'
  </script>
</body>
</html>

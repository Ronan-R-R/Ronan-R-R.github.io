---
const items = [
  {
    date: 'Oct 2025 - Nov 2025',
    role: 'Full Stack Intern',
    company: 'Coast IT Pty (Ltd)',
    description:
      'Collaborated with a team to design and build a full-stack application. Contributed to UI design, database tasks, and security implementation. Used Git for version control in an Agile environment.',
  },
  {
    date: 'June 2025',
    role: 'Intern',
    company: 'Open Vantage',
    description:
      'Contributed to business requirements documentation, user stories, and software modeling. Gained hands-on experience with functional specifications and state flow diagrams.',
  },
  {
    date: '2023 - 2024',
    role: 'Freelance Web Developer',
    company: 'Self-employed',
    description:
      'Designed and developed websites for clients, focusing on responsive design, clean UIs, and meeting specific user requirements.',
  },
  {
    date: '2023 - Present',
    role: 'Software Engineering',
    company: 'CTU Training Solutions, Boksburg',
    description:
      'Studying software development, programming foundations, and system design. Covering the full lifecycle from requirements analysis through to deployment.',
  },
]
---

<section id="experience" class="py-28 lg:py-36" style="background: #090910">
  <div class="container">

    <div class="mb-14" data-reveal>
      <div class="section-tag">
        <span class="inline-block w-6 h-px" style="background: var(--accent)"></span>
        Background
      </div>
      <h2 class="font-display font-bold tracking-tight" style="font-size: clamp(2rem, 4vw, 3rem)">
        Experience &amp; Education
      </h2>
    </div>

    <div class="timeline-container relative max-w-2xl ml-2 md:ml-6">
      <!-- Animated line -->
      <div
        class="timeline-line absolute left-0 top-0 bottom-0 w-px"
        aria-hidden="true"
      ></div>

      {items.map((item) => (
        <div class="relative pl-10 pb-14 last:pb-0" data-timeline-item>
          <!-- Dot -->
          <div
            class="absolute left-0 top-1.5 w-3 h-3 rounded-full -translate-x-[5px]"
            style="background: var(--accent); box-shadow: 0 0 10px rgba(124,92,255,0.6); outline: 3px solid var(--bg)"
            aria-hidden="true"
          ></div>

          <time class="block text-xs font-semibold uppercase tracking-[0.15em] mb-2" style="color: var(--accent)">
            {item.date}
          </time>
          <h3 class="font-display font-bold text-lg mb-0.5">{item.role}</h3>
          <p class="text-sm font-medium mb-3" style="color: var(--muted)">{item.company}</p>
          <p class="text-sm leading-relaxed" style="color: var(--muted)">{item.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

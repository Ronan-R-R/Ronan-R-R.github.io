---

<section id="experience" class="py-28 lg:py-36" style="background: #090910">
  <div class="container">

    <div class="mb-14" data-reveal>
      <div class="section-tag">
        <span class="inline-block w-6 h-px" style="background: var(--accent)"></span>
        Background
      </div>
      <h2 class="font-display font-bold tracking-tight" style="font-size: clamp(2rem, 4vw, 3rem)">
        Experience &amp; Education
      </h2>
    </div>

    <div class="timeline-container relative max-w-2xl ml-2 md:ml-6">
      <!-- Animated line -->
      <div
        class="timeline-line absolute left-0 top-0 bottom-0 w-px"
        aria-hidden="true"
      ></div>

      {items.map((item) => (
        <div class="relative pl-10 pb-14 last:pb-0" data-timeline-item>
          <!-- Dot -->
          <div
            class="absolute left-0 top-1.5 w-3 h-3 rounded-full -translate-x-[5px]"
            style="background: var(--accent); box-shadow: 0 0 10px rgba(124,92,255,0.6); outline: 3px solid #090910"
            aria-hidden="true"
          ></div>

          <div class="flex items-center gap-3 mb-2 flex-wrap">
            <time class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: var(--accent)">
              {item.date}
            </time>
            {item.badge && (
              <span
                class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full"
                style="background: rgba(124,92,255,0.15); color: var(--accent-2); border: 1px solid rgba(124,92,255,0.3)"
              >
                {item.badge}
              </span>
            )}
          </div>
          <h3 class="font-display font-bold text-lg mb-0.5">{item.role}</h3>
          <p class="text-sm font-medium mb-3" style="color: var(--muted)">{item.company}</p>
          <p class="text-sm leading-relaxed" style="color: var(--muted)">{item.description}</p>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <div class="mt-24" data-reveal>
      <div class="section-tag">
        <span class="inline-block w-6 h-px" style="background: var(--accent)"></span>
        Certifications
      </div>
      <h2 class="font-display font-bold tracking-tight mb-10" style="font-size: clamp(1.6rem, 3vw, 2.2rem)">
        Credentials
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" data-reveal-stagger>
        {certs.map((cert) => (
          <div
            class="card p-5 flex flex-col gap-2"
            style="background: rgba(255,255,255,0.02)"
          >
            <div class="flex items-start justify-between gap-3">
              <h3 class="font-semibold text-sm leading-snug" style="color: var(--text)">{cert.name}</h3>
              <span class="text-xs font-medium flex-shrink-0 mt-0.5" style="color: var(--accent)">{cert.year}</span>
            </div>
            <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--muted)">{cert.issuer}</p>
            {cert.detail && (
              <p class="text-xs" style="color: var(--muted); opacity: 0.7">{cert.detail}</p>
            )}
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

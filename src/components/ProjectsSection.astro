---
interface ProjectLink {
  label: string
  href: string
  icon: 'globe' | 'github' | 'download' | 'external'
}

interface Project {
  title: string
  tagline: string
  description: string
  image: string
  imageAlt: string
  stack: string[]
  badge?: string
  links: ProjectLink[]
}

const projects: Project[] = [
  {
    title: 'Echo Software',
    tagline: 'Custom software studio website',
    description:
      'Designed and developed the company website for Echo Software, a Pretoria-based studio building custom digital products for clients.',
    image: '/images/echo-software.svg',
    imageAlt: 'Echo Software company website',
    stack: ['HTML', 'CSS', 'JavaScript'],
    links: [
      { label: 'Visit site', href: 'https://www.echosoftware.co.za', icon: 'globe' },
    ],
  },
  {
    title: 'FFP',
    tagline: 'Fleet Failure Predictor - trucking SaaS',
    description:
      'Built end to end with one other developer: web dashboard, REST API, database, and Flutter mobile app. A fleet management platform for South African trucking companies with offline-first mobile, fuel OCR, trip tracking, and compliance monitoring.',
    image: '/images/ffp.svg',
    imageAlt: 'FFP fleet management platform',
    stack: ['Flutter', 'Dart', 'Firebase', 'Web App'],
    badge: 'Login required',
    links: [
      { label: 'Live app', href: 'https://trucking-predict.web.app', icon: 'external' },
      { label: 'Product page', href: 'https://www.echosoftware.co.za/products/ffp', icon: 'globe' },
    ],
  },
  {
    title: 'Portfolio App',
    tagline: 'Cross-platform mobile app',
    description:
      'A cross-platform mobile application featuring custom UI components, state management, and smooth navigation built with Flutter and Dart.',
    image: '/images/portfolio-app.svg',
    imageAlt: 'Portfolio mobile app preview',
    stack: ['Flutter', 'Dart'],
    links: [
      { label: 'Download', href: 'https://github.com/Ronan-R-R/Portfolio-App/releases/latest', icon: 'download' },
      { label: 'Source', href: 'https://github.com/Ronan-R-R/Portfolio-App', icon: 'github' },
    ],
  },
  {
    title: 'SkyCast',
    tagline: 'Real-time weather dashboard',
    description:
      'Responsive weather app with real-time data from OpenWeatherMap, interactive Leaflet maps, and dynamic UI themes that shift based on live conditions.',
    image: '/images/skycast.svg',
    imageAlt: 'SkyCast weather dashboard',
    stack: ['JavaScript', 'OpenWeather API', 'Leaflet.js'],
    links: [
      { label: 'Live demo', href: 'https://ronan-r-r.github.io/SkyCast/', icon: 'globe' },
      { label: 'Source', href: 'https://github.com/Ronan-R-R/SkyCast', icon: 'github' },
    ],
  },
]

const icons = {
  globe: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  github: `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  download: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  external: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
}
---

<section id="projects" class="py-28 lg:py-36">
  <div class="container">

    <div class="mb-14" data-reveal>
      <div class="section-tag">
        <span class="inline-block w-6 h-px" style="background: var(--accent)"></span>
        Work
      </div>
      <h2 class="font-display font-bold tracking-tight" style="font-size: clamp(2rem, 4vw, 3rem)">
        Featured Projects
      </h2>
      <p class="mt-4 max-w-lg" style="color: var(--muted)">
        A selection of work across web, mobile, and full-stack engineering.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
      {projects.map(project => (
        <article
          class="card flex flex-col overflow-hidden"
          data-tilt
          style="will-change: transform"
        >
          <!-- Preview image -->
          <div class="relative overflow-hidden" style="height: 210px; flex-shrink: 0">
            <img
              src={project.image}
              alt={project.imageAlt}
              width="600"
              height="210"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
            {project.badge && (
              <span
                class="absolute top-3 right-3 text-xs font-semibold px-2.5 py-1 rounded-full"
                style="background: rgba(8,8,13,0.75); border: 1px solid var(--border); color: var(--muted); backdrop-filter: blur(8px)"
              >
                {project.badge}
              </span>
            )}
          </div>

          <!-- Content -->
          <div class="flex flex-col flex-1 p-6 gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1.5" style="color: var(--accent)">{project.tagline}</p>
              <h3 class="font-display font-bold text-xl">{project.title}</h3>
            </div>

            <p class="text-sm leading-relaxed flex-1" style="color: var(--muted)">{project.description}</p>

            <!-- Stack tags -->
            <div class="flex flex-wrap gap-2">
              {project.stack.map(tag => (
                <span class="stack-tag">{tag}</span>
              ))}
            </div>

            <!-- Links -->
            <div
              class="flex flex-wrap gap-4 pt-4"
              style="border-top: 1px solid var(--border)"
            >
              {project.links.map(link => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
                  style="color: var(--muted)"
                  onmouseover="this.style.color='var(--accent-2)'"
                  onmouseout="this.style.color='var(--muted)'"
                >
                  <Fragment set:html={icons[link.icon]} />
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
